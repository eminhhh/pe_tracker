rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function validStatus(v) {
      return v in [
        'assignment',
        'solved in lecture',
        'solved',
        'unsolved'
      ];
    }

    function validProblemDoc() {
      return request.resource.data.keys().hasOnly([
          'statusLabel', 'solvedCount', 'lastSolvedAt', 'difficulty'
        ])
        && validStatus(request.resource.data.statusLabel)
        && request.resource.data.solvedCount is int
        && request.resource.data.solvedCount >= 0
        && (
          !('difficulty' in request.resource.data)
          || request.resource.data.difficulty is string
        )
        && (
          request.resource.data.lastSolvedAt == null
          || request.resource.data.lastSolvedAt is timestamp
        );
    }

    function ownsDisplayName(nameKey) {
      return nameKey is string
        && exists(/databases/$(database)/documents/displayNames/$(nameKey))
        && get(/databases/$(database)/documents/displayNames/$(nameKey)).data.ownerUid == request.auth.uid;
    }

    match /displayNames/{nameKey} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['ownerUid', 'displayName', 'pin', 'updatedAt', 'createdAt'])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.pin is string
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.createdAt is timestamp;
      allow update: if isSignedIn()
        && request.resource.data.keys().hasOnly(['ownerUid', 'displayName', 'pin', 'updatedAt', 'createdAt'])
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.pin is string
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.createdAt is timestamp;
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /problems/{problemId} {
      allow read: if true;
      allow create, update: if isSignedIn() && validProblemDoc();
      allow delete: if false;
    }

    match /solveEvents/{eventId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['problemNumber', 'solvedAt', 'solverUid', 'solverName', 'solverNameKey'])
        && request.resource.data.problemNumber is int
        && request.resource.data.problemNumber >= 1
        && request.resource.data.solvedAt is timestamp
        && request.resource.data.solverUid is string
        && request.resource.data.solverUid == request.auth.uid
        && request.resource.data.solverNameKey is string
        && ownsDisplayName(request.resource.data.solverNameKey)
        && (
          !('solverName' in request.resource.data)
          || request.resource.data.solverName is string
        );
      allow update: if false;
      allow delete: if isSignedIn() && (
        (resource.data.solverUid is string && resource.data.solverUid == request.auth.uid)
        || (resource.data.solverNameKey is string && ownsDisplayName(resource.data.solverNameKey))
        || (resource.data.solverName is string && ownsDisplayName(resource.data.solverName.lower()))
      );
    }
  }
}
